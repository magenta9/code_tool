{
  "name": "@codetool/preload",
  "version": "0.2.0-electron",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --external electron --external @codetool/shared && tsc -p tsconfig.json --noEmit",
    "dev": "tsup src/index.ts --format cjs --watch --external electron --external @codetool/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codetool/shared": "workspace:*"
  }
}
